# Audit service API keys (comma-separated, generated by: python tools/gen_api_key.py)
# Leave empty to disable API key authentication
API_KEYS=

# Claude authentication (configure one of the two)
# Option 1: Anthropic API Key
ANTHROPIC_API_KEY=
# Option 2: Claude Code subscription token
CLAUDE_CODE_TOKEN=

# Skills directory path (default: ./skills)
SKILLS_DIR=./skills

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Max file upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800
